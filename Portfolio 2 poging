      </div>
      <a href="#" class="ov-link" id="ovLink" target="_blank" rel="noopener">
        View on GitHub
        <svg width="14" height="9" viewBox="0 0 14 9" fill="none"><path d="M1 4.5H13M13 4.5L9.5 1M13 4.5L9.5 8" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>
</div>

<script>
const PALETTE=[
  {bar:'#631C22',body:'#f0d8da'},{bar:'#8a8fad',body:'#e0e2f0'},
  {bar:'#440F1C',body:'#e4ccd2'},{bar:'#a09021',body:'#ede8c4'},
  {bar:'#b84e1a',body:'#f2ddd0'},{bar:'#6a9058',body:'#d8e8cc'},
  {bar:'#5a6080',body:'#d8dcee'},{bar:'#8a3a10',body:'#eeddd0'},
  {bar:'#3d5c30',body:'#d2e6c8'},{bar:'#7a5030',body:'#ecddd0'},
];

// ✏️ UPDATE: edit your projects here
const PROJECTS=[
  {file:'ficq-partners.jpg',type:'image',title:'FICQ <em>Partners</em>',cat:'Brand Identity',desc:'A complete brand identity system for FICQ Partners — wordmark, colour palette, typography, and application across print and digital touchpoints.',tags:['Branding','Identity','Print','Figma'],link:'https://github.com/yourusername/ficq-partners',w:260,h:210},
  {file:'groenteboer.jpg',type:'image',title:'Groente<em>boer</em>',cat:'Visual Identity',desc:'Brand identity and packaging design for a local Rotterdam greengrocers. Rooted in warmth, colour, and neighbourhood culture.',tags:['Branding','Packaging','Illustration'],link:'https://github.com/yourusername/groenteboer',w:240,h:200},
  {file:'japan-2024.jpg',type:'image',title:'Japan <em>2024</em>',cat:'Photography',desc:'A photographic diary from a three-week journey through Japan — exploring light, ritual, and the quiet tension between old and new.',tags:['Photography','Editorial','Lightroom'],link:'https://github.com/yourusername/japan-2024',w:250,h:220},
  {file:'juul1.jpg',type:'image',title:'Juul <em>Portrait</em>',cat:'Photography',desc:'Portrait series shot on location — exploring identity, stillness, and the space between subject and camera.',tags:['Photography','Portrait','Natural light'],link:'https://github.com/yourusername/juul',w:230,h:200},
  {file:'postkaartje1.png',type:'image',title:'Postcard <em>Series I</em>',cat:'Print Design',desc:'First edition of a self-initiated postcard series — hand-designed and printed in a limited run of 50.',tags:['Print','Illustration','Risograph'],link:'https://github.com/yourusername/postkaartjes',w:270,h:190},
  {file:'postkaartje2.png',type:'image',title:'Postcard <em>Series II</em>',cat:'Print Design',desc:'Second edition pushed further into abstraction.',tags:['Print','Illustration','Typography'],link:'https://github.com/yourusername/postkaartjes',w:270,h:190},
  {file:'postkaartje3.png',type:'image',title:'Postcard <em>Series III</em>',cat:'Print Design',desc:'Third and final edition — colour, composition, and form at their limits.',tags:['Print','Colour','Composition'],link:'https://github.com/yourusername/postkaartjes',w:270,h:190},
  {file:'song1.jpg',audioFile:'song1.mp3',type:'audio',title:'Track <em>One</em>',cat:'Music / Sound',desc:'An original composition exploring ambient texture and rhythm. Produced entirely independently.',tags:['Music','Production','Ambient'],link:'https://github.com/yourusername/music',w:240,h:160},
  {file:'song2.jpg',audioFile:'song2.mp3',type:'audio',title:'Track <em>Two</em>',cat:'Music / Sound',desc:'Second original track — rhythmic, percussive, pushing into experimental territory.',tags:['Music','Production','Experimental'],link:'https://github.com/yourusername/music',w:240,h:160},
  {file:'emma-foto.png',type:'image',title:'Emma <em>Portrait</em>',cat:'Photography',desc:'Portrait session focused on natural light and candid emotion.',tags:['Photography','Portrait','Natural light'],link:'https://github.com/yourusername/portraits',w:230,h:210},
];

const $cur=document.getElementById('cursor');
document.addEventListener('mousemove',e=>{$cur.style.left=e.clientX+'px';$cur.style.top=e.clientY+'px'});

let zStack=10;
function raise(el){el.style.zIndex=++zStack}

const winEls=[],floats=[];
const vw=()=>window.innerWidth,vh=()=>window.innerHeight;

PROJECTS.forEach((proj,idx)=>{
  const pal=PALETTE[idx%PALETTE.length];
  const win=document.createElement('div');
  win.className='win';
  win.style.width=proj.w+'px';
  const pad=60;
  const bx=pad+Math.random()*(vw()-proj.w-pad*2);
  const by=pad+Math.random()*(vh()-proj.h-30-pad*2);
  win.style.left=bx+'px';win.style.top=by+'px';win.style.zIndex=idx+1;

  const bar=document.createElement('div');
  bar.className='win-bar';bar.style.background=pal.bar;
  bar.innerHTML=`<div class="win-dots"><div class="win-dot r"></div><div class="win-dot y"></div><div class="win-dot g"></div></div><div class="win-title">${proj.title.replace(/<[^>]+>/g,'')} — ${proj.cat}</div>`;
  win.appendChild(bar);

  const body=document.createElement('div');
  body.style.height=proj.h+'px';body.style.background=pal.body;

  if(proj.type==='audio'){
    body.className='win-body win-audio';
    const cover=document.createElement('div');cover.className='win-audio-cover';
    const ci=document.createElement('img');ci.src=proj.file;ci.draggable=false;
    cover.appendChild(ci);body.appendChild(cover);
    const au=document.createElement('audio');au.controls=true;au.preload='none';au.src=proj.audioFile;
    body.appendChild(au);
  } else {
    body.className='win-body';
    const img=document.createElement('img');img.src=proj.file;img.draggable=false;img.alt=proj.title.replace(/<[^>]+>/g,'');
    img.onerror=()=>{img.remove();const ph=document.createElement('div');ph.className='win-ph';ph.textContent=proj.cat;body.insertBefore(ph,body.firstChild)};
    body.appendChild(img);
    const hint=document.createElement('div');hint.className='win-hint';hint.innerHTML='<span>Click to view ↗</span>';
    body.appendChild(hint);
  }
  win.appendChild(body);
  document.body.appendChild(win);
  winEls.push(win);
  floats.push({baseX:bx,baseY:by,ampX:3+Math.random()*7,ampY:4+Math.random()*9,spdX:.22+Math.random()*.32,spdY:.18+Math.random()*.28,phX:Math.random()*Math.PI*2,phY:Math.random()*Math.PI*2,active:false});
});

let activeWin=-1,dragOX=0,dragOY=0,dragMoved=false;

winEls.forEach((win,idx)=>{
  const proj=PROJECTS[idx];
  const bar=win.querySelector('.win-bar');
  const body=win.querySelector('.win-body,.win-audio');
  function startDrag(ex,ey){activeWin=idx;dragOX=ex-floats[idx].baseX;dragOY=ey-floats[idx].baseY;dragMoved=false;floats[idx].active=true;raise(win);win.classList.add('is-dragging')}
  bar.addEventListener('mousedown',e=>{e.preventDefault();startDrag(e.clientX,e.clientY)});
  bar.addEventListener('touchstart',e=>startDrag(e.touches[0].clientX,e.touches[0].clientY),{passive:true});
  if(proj.type!=='audio'){
    body.addEventListener('mousedown',e=>{e.preventDefault();startDrag(e.clientX,e.clientY)});
    body.addEventListener('touchstart',e=>startDrag(e.touches[0].clientX,e.touches[0].clientY),{passive:true});
  } else {
    win.addEventListener('mousedown',()=>raise(win));
  }
});

document.addEventListener('mousemove',e=>{
  if(activeWin===-1)return;
  const nx=e.clientX-dragOX,ny=e.clientY-dragOY;
  if(Math.abs(nx-floats[activeWin].baseX)+Math.abs(ny-floats[activeWin].baseY)>4)dragMoved=true;
  floats[activeWin].baseX=nx;floats[activeWin].baseY=ny;
});
document.addEventListener('touchmove',e=>{
  if(activeWin===-1)return;
  dragMoved=true;floats[activeWin].baseX=e.touches[0].clientX-dragOX;floats[activeWin].baseY=e.touches[0].clientY-dragOY;
},{passive:true});
function endDrag(){
  if(activeWin===-1)return;
  winEls[activeWin].classList.remove('is-dragging');floats[activeWin].active=false;
  if(!dragMoved)openOverlay(activeWin);
  activeWin=-1;
}
document.addEventListener('mouseup',endDrag);
document.addEventListener('touchend',endDrag);

function animate(ts){
  ts*=.001;
  winEls.forEach((win,i)=>{
    const f=floats[i];
    const fx=f.active?0:Math.sin(ts*f.spdX+f.phX)*f.ampX;
    const fy=f.active?0:Math.cos(ts*f.spdY+f.phY)*f.ampY;
    win.style.left=(f.baseX+fx)+'px';win.style.top=(f.baseY+fy)+'px';
  });
  requestAnimationFrame(animate);
}
requestAnimationFrame(animate);

const $overlay=document.getElementById('overlay');
const $ovMedia=document.getElementById('ovMedia');
let $curAudio=null;

function openOverlay(idx){
  const proj=PROJECTS[idx],pal=PALETTE[idx%PALETTE.length];
  document.getElementById('ovIndex').textContent=String(idx+1).padStart(2,'0');
  document.getElementById('ovCat').textContent=proj.cat;
  document.getElementById('ovTitle').innerHTML=proj.title;
  document.getElementById('ovDesc').textContent=proj.desc;
  document.getElementById('ovTags').innerHTML=proj.tags.map(t=>`<span class="ov-tag">${t}</span>`).join('');
  document.getElementById('ovLink').href=proj.link;
  $ovMedia.innerHTML='';
  if(proj.type==='audio'){
    $ovMedia.style.background='#111';
    const wrap=document.createElement('div');wrap.className='ov-audio-body';
    const cover=document.createElement('div');cover.className='ov-audio-cover';
    const ci=document.createElement('img');ci.src=proj.file;cover.appendChild(ci);wrap.appendChild(cover);
    const au=document.createElement('audio');au.controls=true;au.src=proj.audioFile;$curAudio=au;wrap.appendChild(au);
    $ovMedia.appendChild(wrap);
  } else {
    $ovMedia.style.background=pal.body;
    const img=document.createElement('img');img.src=proj.file;img.alt=proj.title.replace(/<[^>]+>/g,'');
    $ovMedia.appendChild(img);
  }
  $overlay.classList.add('open');
}
function closeOverlay(){$overlay.classList.remove('open');if($curAudio){$curAudio.pause();$curAudio=null}}
document.getElementById('ovClose').addEventListener('click',closeOverlay);
document.getElementById('ovBackdrop').addEventListener('click',closeOverlay);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeOverlay()});

function setTab(view,btn){
  document.querySelectorAll('.bar-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel').classList.toggle('visible',view==='studio');
}

const $ticker=document.getElementById('ticker');
let tp=0;
(function runTicker(){tp-=.38;if(Math.abs(tp)>$ticker.scrollWidth/2)tp=0;$ticker.style.transform=`translateX(${tp}px)`;requestAnimationFrame(runTicker)})();
</script>
</body>
</html> 

