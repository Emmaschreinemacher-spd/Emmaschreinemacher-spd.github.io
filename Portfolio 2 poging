</div>

<!-- Bottom bar -->
<div class="bar">
  <button class="bar-btn active" onclick="setTab('work',this)">Work</button>
  <button class="bar-btn" onclick="setTab('index',this)">Index</button>
  <button class="bar-btn" onclick="setTab('studio',this)">Studio</button>
  <button class="bar-btn" onclick="setTab('news',this)">News</button>
  <div class="bar-divider"></div>
  <!-- ✏️ UPDATE: ticker text -->
  <div class="bar-news" id="ticker">↳&nbsp; FICQ Partners identity &nbsp;·&nbsp; Japan 2024 &nbsp;·&nbsp; Postcard Series I–III &nbsp;·&nbsp; Available for freelance &nbsp;·&nbsp;</div>
</div>

<!-- Detail overlay -->
<div id="overlay">
  <div class="ov-backdrop" id="ovBackdrop"></div>
  <div class="ov-window">
    <button class="ov-close" id="ovClose" aria-label="Close">
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><line x1="1" y1="1" x2="10" y2="10" stroke="#444" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="1" x2="1" y2="10" stroke="#444" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
    <div class="ov-media" id="ovMedia"></div>
