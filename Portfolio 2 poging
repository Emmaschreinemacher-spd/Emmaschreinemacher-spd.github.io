<!-- Studio panel -->
<div class="panel" id="panel">
  <!-- ✏️ UPDATE -->
  <div class="panel-statement">A multidisciplinary creative working at the intersection of design, code, and visual culture. Based in Rotterdam.</div>
  <div class="panel-cols">
